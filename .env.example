# Configuration example for Magalie v3.1
# Copy this file to .env and fill in your actual values

# Supabase Local Development
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ClawBuddy Integration
CLAWBUDDY_API_URL=http://127.0.0.1:54321
CLAWBUDDY_WEBHOOK_SECRET=your_webhook_secret_here

# Project Configuration
PROJECT_ID=mission-control-v2

# GitHub API (for deployments)
GITHUB_TOKEN=your_github_personal_access_token_here
GH_TOKEN=your_github_personal_access_token_here

# OpenClaw Configuration
OPENCLAW_WORKSPACE=/Users/house/.openclaw/workspace-main/magalie-v3.1
OPENCLAW_GATEWAY_URL=http://localhost:18789

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres